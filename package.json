{
  "name": "unipath",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n client,server -c cyan,yellow \"pnpm --filter @unipath/client dev\" \"pnpm --filter @unipath/server dev\"",
    "dev:client": "pnpm --filter @unipath/client dev",
    "dev:server": "pnpm --filter @unipath/server dev"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
